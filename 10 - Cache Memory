.MODEL SMALL
.STACK 100H

.DATA
MSG1 DB 'Block Number = $'
MSG2 DB 0DH,0AH,'Cache Line = $'
MSG3 DB 0DH,0AH,'Tag = $'

BLOCK DB 13        ; Example memory block
LINES DB 4         ; Number of cache lines

.CODE
MAIN PROC
    MOV AX, @DATA
    MOV DS, AX

    ; Print Block Number
    MOV DX, OFFSET MSG1
    MOV AH, 09H
    INT 21H

    MOV AL, BLOCK
    ADD AL, 30H
    MOV DL, AL
    MOV AH, 02H
    INT 21H

    ; -------- Direct Mapping --------
    MOV AL, BLOCK
    MOV BL, LINES
    XOR AH, AH
    DIV BL          ; AL=Tag, AH=Index

    ; Print Cache Line (Index)
    MOV DX, OFFSET MSG2
    MOV AH, 09H
    INT 21H

    MOV DL, AH
    ADD DL, 30H
    MOV AH, 02H
    INT 21H

    ; Print Tag
    MOV DX, OFFSET MSG3
    MOV AH, 09H
    INT 21H

    MOV DL, AL
    ADD DL, 30H
    MOV AH, 02H
    INT 21H

    ; Exit
    MOV AH, 4CH
    INT 21H

MAIN ENDP
END MAIN
