.MODEL SMALL
.STACK 100H

.DATA
MSG DB 'Result = $'
M   DB 5        ; Multiplicand
Q   DB 3        ; Multiplier

.CODE
MAIN PROC
    MOV AX, @DATA
    MOV DS, AX

    ; Initialize
    MOV AL, Q        ; Q in AL
    MOV BL, M        ; M in BL
    XOR AH, AH       ; A = 0
    MOV BH, 0        ; Q-1 = 0
    MOV CX, 8        ; 8-bit count

BOOTH:
    MOV DL, AL
    AND DL, 01H      ; Q0

    CMP DL, BH
    JE SHIFT

    CMP DL, 01H
    JE SUBT

ADD:
    ADD AH, BL       ; A = A + M
    JMP SHIFT

SUBT:
    SUB AH, BL       ; A = A - M

SHIFT:
    MOV BH, AL
    AND BH, 01H      ; Update Q-1

    SAR AH, 1        ; Arithmetic shift A
    RCR AL, 1        ; Rotate Q with carry

    LOOP BOOTH

    ; Result is in AX (AH:AL)
    ; For small numbers, AL is enough
    MOV AL, AH       ; move result to AL

    ; -------- PRINT RESULT --------
    MOV DX, OFFSET MSG
    MOV AH, 09H
    INT 21H

    MOV AH, 0
    MOV BL, 10
    DIV BL           ; AL=quotient, AH=remainder

    ADD AL, 30H
    MOV DL, AL
    MOV AH, 02H
    INT 21H

    MOV AL, AH
    ADD AL, 30H
    MOV DL, AL
    MOV AH, 02H
    INT 21H

    MOV AH, 4CH
    INT 21H

MAIN ENDP
END MAIN
