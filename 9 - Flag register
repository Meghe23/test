.MODEL SMALL
.STACK 100H

.DATA
MSG DB 'FLAGS = $'

.CODE
MAIN PROC
    MOV AX, @DATA
    MOV DS, AX

    ; Print message
    MOV DX, OFFSET MSG
    MOV AH, 09H
    INT 21H

    ; Get FLAGS into AX
    PUSHF
    POP AX

    MOV CX, 16        ; 16 bits to display

PRINT_BITS:
    ROL AX, 1         ; rotate left, MSB → CF
    JC PRINT_1

PRINT_0:
    MOV DL, '0'
    JMP DISPLAY

PRINT_1:
    MOV DL, '1'

DISPLAY:
    MOV AH, 02H
    INT 21H

    LOOP PRINT_BITS

    ; Exit
    MOV AH, 4CH
    INT 21H

MAIN ENDP
END MAIN
