.MODEL SMALL 
.STACK 100H 
.DATA 
; File name must be null-terminated (0) 
filename    DB "test.txt", 0 
; Data to write into the file 
content     DB "Hello, DOS File! This was written using INT 21H." 
content_len DW $ - content   ; Calculate length of content automatically 
; Messages for display 
msg_success DB "File created and written successfully!$" 
msg_error   DB "An error occurred during file operation.$" 
; Variable to store the File Handle 
fhandle     DW ? 
.CODE 
START: 
; Initialize Data Segment 
MOV AX, @DATA 
MOV DS, AX 
; --- STEP 1: CREATE FILE (AH = 3Ch) --- 
MOV AH, 3CH
         ;
 Function to create file 
LEA DX, filename    ; DX points to filename 
MOV CX, 00H
INT 21H
         ; 
             ;
Attribute: 00 = Normal file 
 Call DOS 
JC  ERROR_EXIT      ; If Carry Flag is set, error occurred 
MOV fhandle, AX     ; Store returned File Handle in AX 
; --- STEP 2: WRITE TO FILE (AH = 40h) --- 
MOV AH, 40H
         ;
 Function to write to file 
MOV BX, fhandle     ; BX must contain the handle 
MOV CX, content_len ; CX = number of bytes to write 
LEA DX, content     ; DS:DX points to data buffer 
INT 21H
             ;
 Call DOS 
JC  ERROR_EXIT      ; Jump if error 
; --- STEP 3: CLOSE FILE (AH = 3Eh) --- 
MOV AH, 3EH
         ;
 Function to close file 
MOV BX, fhandle     ; BX = handle to close 
INT 21H
             ;
 Call DOS 
JC  ERROR_EXIT 
; --- SUCCESS MESSAGE --- 
LEA DX, msg_success 
MOV AH, 09H
INT 21H 
JMP FINAL_EXIT 
         ;
 Display string function 
ERROR_EXIT: 
LEA DX, msg_error 
MOV AH, 09H 
INT 21H 
FINAL_EXIT: 
; --- STEP 4: TERMINATE PROGRAM (AH = 4Ch) --- 
MOV AH, 4CH 
INT 21H 
END START
